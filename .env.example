# Banco de dados (Docker Compose)
POSTGRES_USER=atjewel
POSTGRES_PASSWORD=changeme
POSTGRES_DB=atjewel_dev

# Banco de dados (local sem Docker)
DATABASE_URL=postgresql://atjewel:changeme@localhost:5432/atjewel_dev

# Aplicacao
PORT=3000
NODE_ENV=development
TZ=America/Sao_Paulo

# CORS - lista separada por virgula, sem espacos
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT (auth admin)
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_random_hex

# Criptografia de PII (AES-256-GCM) - 32 bytes em hex (64 chars)
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_random_hex_32_bytes

# Hash HMAC-SHA256 para campos *_hash
# IMPORTANTE: chave DIFERENTE da ENCRYPTION_KEY
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HASH_SECRET=replace_with_random_hex_32_bytes

# Integracao ERP Safira
SAFIRA_API_KEY=replace_with_real_key

# Agentes internos (Anastasia-analytics / Elena-catalogo) via Anthropic SDK.
# Sem a chave, os endpoints /agentes/*/chat respondem 500 (os demais funcionam).
ANTHROPIC_API_KEY=replace_with_anthropic_key
# Modelos por agente (defaults se ausentes: opus-4-8 / sonnet-4-6)
ANTHROPIC_MODEL_ANASTASIA=claude-opus-4-8
ANTHROPIC_MODEL_ELENA=claude-sonnet-4-6

# Login com Google (OIDC). Client ID do OAuth 2.0 criado no Google Cloud
# Console (tipo "Aplicativo Web"). Vazio = login Google desabilitado.
# Deve ser igual ao NEXT_PUBLIC_GOOGLE_CLIENT_ID do front.
GOOGLE_CLIENT_ID=replace_with_google_oauth_client_id
